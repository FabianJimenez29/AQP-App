{
  "name": "aqp-app",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear",
    "start:fresh": "expo start --clear --no-dev",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "clear": "rm -rf .expo node_modules/.cache && expo start --clear",
    "build:preview": "npx eas-cli build --platform android --profile preview",
    "build:production": "npx eas-cli build --platform android --profile production",
    "build:local": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease",
    "app:bump": "node ./scripts/app-bump-version.js",
    "app:update-backend": "node ./scripts/app-update-backend.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.5",
    "@reduxjs/toolkit": "^2.11.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.7",
    "expo-camera": "~55.0.10",
    "expo-constants": "~55.0.8",
    "expo-dev-client": "~55.0.17",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-picker": "^55.0.13",
    "expo-intent-launcher": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-media-library": "~55.0.10",
    "expo-modules-core": "^55.0.16",
    "expo-print": "^55.0.9",
    "expo-sharing": "~55.0.12",
    "expo-splash-screen": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.14",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.84.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.7.4",
    "react-redux": "^9.2.0",
    "rn-fetch-blob": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "eas-cli": "^18.4.0",
    "eslint": "^10.0.3",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=25",
    "npm": ">=11"
  },
  "private": true
}
